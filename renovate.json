{
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update _VERSION variables in Dockerfiles",
      "managerFilePatterns": [
        "/(^|/|\\.)[dD]ockerfile$/",
        "/(^|/)[dD]ockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s(?:ENV|ARG) .+?_VERSION=(?<currentValue>.+?)\\s"
      ]
    },
    {
      "customType": "regex",
      "description": "Update _VERSION variables in github actions",
      "managerFilePatterns": [
        "/(^|/)\\.github\/workflows\/raft\\.build\\.yml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s.+?_VERSION: (?<currentValue>.+?)\\s"
      ]
    },
    {
      "customType": "regex",
      "description": "Update _VERSION variables in README.md",
      "managerFilePatterns": [
        "/^README\\.md$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))?\\s(?:export) .+?_VERSION=(?<currentValue>.+?)\\s"
      ]
    }
  ],
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    "group:githubArtifactActions",
    "group:linters",
    "schedule:automergeNonOfficeHours",
    "security:openssf-scorecard"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchPackageNames": ["@botiverse/raft*"],
      "minimumReleaseAge": null
    },
    {
      "matchDatasources": ["node-version"],
      "matchPackageNames": ["node"],
      "allowedVersions": "/^24\\./"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchPackageNames": ["@botiverse/raft*", "@openai/codex"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["digest"],
      "matchDatasources": ["docker"],
      "minimumReleaseAge": null,
      "automerge": true
    },
    {
      "description": "Batch repository-produced image digest updates to reduce self-triggering build loops.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/\\/icecodexi\\//"],
      "matchUpdateTypes": ["digest"],
      "minimumReleaseAge": "12 hours",
      "schedule": ["after 12am and before 1am", "after 12pm and before 1pm"],
      "automerge": true
    }
  ],
  "automergeType": "branch",
  "timezone": "Asia/Shanghai"
}
